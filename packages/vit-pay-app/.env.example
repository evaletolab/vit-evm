# Template — copier en .env (gitignored) et remplir.
# Utilisation : node --env-file=.env scripts/guardian-trigger-recovery.mjs

# Private key du guardian qui appelle SocialRecoveryModule.confirmRecovery.
# En dev/Sepolia, on utilise volontiers le compte Hardhat #0 (public, sans valeur) :
#   0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# En mainnet, mettre une vraie clé contrôlée — ne jamais la commit.
GUARDIAN_PK=

# RPC override optionnel (défaut : publicnode Sepolia)
RPC_URL=
